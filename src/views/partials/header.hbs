<header class="header">
  <div class="header--inner clearfix">
    <div class="header--inner--logo">
      <a href="/"><h1><img src="logo.png"></h1></a>
    </div>
    <nav class="header--inner--gnav">
      <!-- This list should change dynamically based on user role.-->
      <ul class="clearfix">
        <li><a href="/">Homepage</a></li>
        <li><a href="/users">Users</a></li>
        {{#if userRole}}
          <li><a href="/me">My Profile</a></li>
          <li><a href="/logout">Log Out</a></li>
        {{/if}}
        {{#unless userRole}}
          <li><a href="/login">Log In</a></li>
        {{/unless}}
      </ul>
    </nav>
  </div>
</header>
